#version 460 core
layout(local_size_x = 64) in;

// Wypełnia bufor wartościami {0, 1, 2, ..., elementCount-1}
// Zastępuje CPU-side std::iota + glBufferSubData co klatkę.
layout(std430, binding = 0) writeonly buffer Values {
    uint values[];
};

uniform uint elementCount;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= elementCount) return;
    values[i] = i;
}
