#version 460 core
layout(local_size_x = 64) in;

// ============================================================
// write_pass.comp
// Iteruje po sortedIndices[] (wynik radix sort) i przepisuje
// dane do instances[] w kolejności posortowanej po (materialID|meshID).
// Sąsiednie wątki piszą do sąsiednich adresów → pełna koalescencja.
// ============================================================

struct RenderData {
    mat4 model;
    vec4 aabbMin;
    vec4 aabbMax;
    uint meshID;
    uint materialID;
    uint skeletonID;
    uint padding;
};

//struct MeshMeta {
//    uint instanceOffset; // wypełniony przez prefix-sum na CPU
//    uint instanceCount;  // atomic — ile już zapisano (reset przed tym przebiegiem)
//    uint pad0;
//    uint pad1;
//};

struct InstanceData {
    mat4 model;
    uint materialID;
    uint objectID;
    uint pad0;
    uint pad1;
};

// binding = 0 : źródłowe dane obiektów
layout(std430, binding = 0) readonly buffer Objects {
    RenderData objects[];
};

// binding = 1 : wynik radix sort — indeksy w kolejności posortowanej
layout(std430, binding = 1) readonly buffer SortedIndices {
    uint sortedIndices[];
};

// binding = 2 : wyjściowy bufor instancji dla GPU (indirect draw)
layout(std430, binding = 2) writeonly buffer Instances {
    InstanceData instances[];
};

//// binding = 3 : metadane meshy — atomicAdd zlicza instancje per mesh
//layout(std430, binding = 3) buffer MeshMeta_buf {
//    MeshMeta meshMeta[];
//};
//
uniform uint visibleCount;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= visibleCount) return;

    uint objID = sortedIndices[i];
    RenderData obj = objects[objID];

    // Zapis sekwencyjny — i odpowiada pozycji w tablicy instancji.
    // Wątki sąsiednie piszą do sąsiednich adresów → pełna koalescencja zapisu.
    instances[i].model      = obj.model;
    instances[i].materialID = obj.materialID;
    instances[i].objectID   = objID;

//    atomicAdd(meshMeta[obj.meshID].instanceCount, 1u);
}








